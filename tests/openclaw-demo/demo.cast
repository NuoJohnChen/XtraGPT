[5.62113, "o", "\u001b[1;34mdemo@xtragpt\u001b[0m \u001b[1;32m$\u001b[0m head -25 openclaw/skills/skill.xtragpt-paper-revision-skill.yaml"]
[6.222522, "o", "\r\n"]
[6.225375, "o", "version: 1\r\nskill:\r\n  id: xtragpt-paper-revision-skill\r\n"]
[6.225419, "o", "  display_name: XtraGPT Paper Revision Skill\r\n  description: >-\r\n    A specialized academic paper revision skill backed by XtraGPT. It is intended\r\n    for revising abstracts, introductions, methods, evaluation sections,\r\n"]
[6.225465, "o", "    conclusions, rebuttals, and reviewer responses while preserving technical\r\n    meaning and paper-level consistency.\r\n  enabled: true\r\n\r\nrouting:\r\n  auto_invoke: true\r\n  priority: 90\r\n  stop_after_match: true\r\n  positive_triggers:\r\n    verbs:\r\n      - revise\r\n      - rewrite\r\n      - polish\r\n      - edit\r\n"]
[6.225502, "o", "      - improve\r\n      - refine\r\n      - shorten\r\n      - compress\r\n"]
